{
  "metadata": {
    "source": "Udyam Registration Portal - Official Government of India",
    "version": "2.0",
    "description": "Complete JSON schema for Udyam Registration Steps 1 & 2",
    "created_date": "2026-07-03",
    "note": "Based on official government documentation and verified form structure"
  },
  "step1": {
    "title": "Step 1: Aadhaar & OTP Verification",
    "description": "Verify Aadhaar number and receive OTP for authentication",
    "fields": [
      {
        "id": "aadhaar_number",
        "name": "AadhaarNo",
        "label": "Aadhaar Number",
        "type": "input",
        "input_type": "text",
        "placeholder": "Enter 12-digit Aadhaar number",
        "required": true,
        "validation": {
          "pattern": "^\\d{12}$",
          "min_length": 12,
          "max_length": 12,
          "error_message": "Aadhaar must be 12 digits"
        },
        "hint": "12-digit Aadhaar number as issued by UIDAI"
      },
      {
        "id": "aadhaar_consent",
        "name": "AadhaarConsent",
        "label": "I give consent to retrieve my UIDAI data from Aadhaar database",
        "type": "checkbox",
        "required": true,
        "validation": {
          "must_be_checked": true
        },
        "hint": "You must consent to proceed with Aadhaar verification"
      },
      {
        "id": "get_otp_button",
        "name": "GetOTP",
        "label": "Get OTP",
        "type": "button",
        "action": "request_otp",
        "disabled_until": ["aadhaar_number", "aadhaar_consent"],
        "hint": "Click to receive 6-digit OTP on registered mobile"
      },
      {
        "id": "otp",
        "name": "OTP",
        "label": "One Time Password (OTP)",
        "type": "input",
        "input_type": "text",
        "placeholder": "Enter 6-digit OTP",
        "required": true,
        "validation": {
          "pattern": "^\\d{6}$",
          "min_length": 6,
          "max_length": 6,
          "error_message": "OTP must be 6 digits"
        },
        "conditional": "shown_after_otp_request",
        "hint": "6-digit OTP sent to your registered mobile number",
        "resend_timeout": 60
      },
      {
        "id": "verify_otp_button",
        "name": "VerifyOTP",
        "label": "Verify OTP",
        "type": "button",
        "action": "verify_otp",
        "disabled_until": ["otp"],
        "conditional": "shown_after_otp_request"
      },
      {
        "id": "resend_otp_button",
        "name": "ResendOTP",
        "label": "Resend OTP",
        "type": "button",
        "action": "resend_otp",
        "style": "secondary",
        "conditional": "shown_after_otp_request"
      }
    ],
    "flow_logic": {
      "initial_state": "enter_aadhaar",
      "states": {
        "enter_aadhaar": {
          "visible_fields": ["aadhaar_number", "aadhaar_consent", "get_otp_button"],
          "next_state": "wait_otp"
        },
        "wait_otp": {
          "visible_fields": ["otp", "verify_otp_button", "resend_otp_button"],
          "next_state": "verify_otp"
        },
        "verify_otp": {
          "api_call": "POST /api/verify-otp",
          "on_success": "PROCEED_TO_STEP2",
          "on_failure": "reset_to_wait_otp"
        }
      }
    }
  },
  "step2": {
    "title": "Step 2: PAN Verification & Business Details",
    "description": "Verify PAN and enter basic business information",
    "fields": [
      {
        "id": "pan_number",
        "name": "PANNo",
        "label": "Permanent Account Number (PAN)",
        "type": "input",
        "input_type": "text",
        "placeholder": "e.g., ABCDE1234F",
        "required": true,
        "validation": {
          "pattern": "^[A-Z]{5}[0-9]{4}[A-Z]{1}$",
          "length": 10,
          "error_message": "PAN format: ABCDE1234F",
          "description": "5 letters + 4 digits + 1 letter"
        },
        "hint": "PAN as issued by Income Tax Department",
        "auto_uppercase": true
      },
      {
        "id": "pan_name",
        "name": "PANName",
        "label": "Name as per PAN",
        "type": "input",
        "input_type": "text",
        "placeholder": "Enter full name",
        "required": true,
        "validation": {
          "min_length": 3,
          "max_length": 100,
          "pattern": "^[a-zA-Z\\s\\-\\.]*$",
          "error_message": "Name must contain only letters, spaces, hyphens, and periods"
